	measure 'Other | Selected Approval Time' =
			
			// "Approval Speed: " &
			// VAR SelectedValues =
			//     VALUES(f_Orders[approval_speed_bucket])
			
			// VAR CountSelected =
			//     COUNTROWS(SelectedValues)
			
			// VAR CountAll =
			//     COUNTROWS(ALL(f_Orders[approval_speed_bucket]))
			
			// RETURN
			// IF(
			//     CountSelected = CountAll,
			//     "All",
			//     CONCATENATEX(
			//         SelectedValues,
			//         f_Orders[approval_speed_bucket],
			//         ", "
			//     )
			// )
			
			
			"Approval Speed: " &
			VAR SelectedValues =
			    VALUES('_approval_speed'[approval_speed_bucket])
			
			VAR CountSelected =
			    COUNTROWS(SelectedValues)
			
			VAR CountAll =
			    CALCULATE(
			        DISTINCTCOUNT('_approval_speed'[approval_speed_bucket]),
			        ALL('_approval_speed')
			    )
			
			RETURN
			IF(
			    CountSelected >= CountAll,
			    "All",
			    CONCATENATEX(
			        SelectedValues,
			        '_approval_speed'[approval_speed_bucket],
			        ", ",
			        CALCULATE(MAX('_approval_speed'[approval_speed_sort])),
			        ASC
			    )
			)
		displayFolder: Other
		lineageTag: a465d1c3-009e-43eb-9755-c578bc910174

	measure 'Finance | Gross Revenue % of Total (state_name)' =
			
