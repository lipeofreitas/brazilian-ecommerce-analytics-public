	measure 'KPI | Avg Delivery Lead Time by Product Category' =
			
			VAR OrdersFromItems =
			    VALUES(f_Order_items[order_id])
			RETURN
			CALCULATE(
			    AVERAGEX(
			        f_Orders,
			        DATEDIFF(
			            f_Orders[order_purchase_ts],
			            f_Orders[order_delivered_customer_ts],
			            DAY
			        )
			    ),
			    TREATAS(OrdersFromItems, f_Orders[order_id])
			)
		displayFolder: KPI
		lineageTag: a074a584-81d2-45cf-b441-2acd2ec9ae44

		annotation PBI_FormatHint = {"isGeneralNumber":true}

