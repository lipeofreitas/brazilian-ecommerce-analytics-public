	measure 'Time | Dynamic Rolling Revenue (Approved)' = ```
			
			
			// VAR EndDateFromSelection =
			//     MAX('Calendar'[YearMonthSort])               
			// VAR EndDateWithData =
			//     CALCULATE(
			//         MAX(f_Orders[order_approved_ts]),
			//         REMOVEFILTERS('Calendar')
			//     )
			// VAR EndDate =
			//     MIN(EndDateFromSelection, EndDateWithData)
			// VAR MonthsBack =
			//     COALESCE([Time | Selected Rolling Months], 24)
			// VAR FINAL =
			//     CALCULATE(
			//         [Finance | Gross Revenue],
			//         DATESINPERIOD('Calendar'[full_date], EndDate, -MonthsBack, MONTH)
			//     )
			
			// RETURN FINAL
			
			VAR EndDateFromSelection =
			    MAX('Calendar'[full_date])
			
			VAR EndDateWithData =
			    CALCULATE(
			        MAX(f_Orders[order_approved_ts]),
			        REMOVEFILTERS('Calendar')
			    )
			
			VAR EndDate =
			    MIN(EndDateFromSelection, EndDateWithData)
			
			VAR MonthsBack =
			    COALESCE([Time | Selected Rolling Months], 12)
			
			RETURN
			CALCULATE(
			    [Finance | Gross Revenue],
			    DATESINPERIOD(
			        'Calendar'[full_date],
			        EndDate,
			        -MonthsBack,
			        MONTH
			    )
			)
			
			
			```
		displayFolder: Time
		lineageTag: 655d8f57-1ced-4354-aec5-29b3707fb86c

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

