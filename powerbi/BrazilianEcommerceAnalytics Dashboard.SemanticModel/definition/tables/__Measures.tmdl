	measure 'KPI | ABC Orders Pareto %' =
			
			VAR CurrentOrders =
			    [Other | Orders by Product Category]
			
			VAR CategorySummary =
			    ADDCOLUMNS(
			        ALLSELECTED(d_Products[product_category_group]),
			        "@Orders", [Other | Orders by Product Category]
			    )
			
			VAR TotalOrders =
			    SUMX(CategorySummary, [@Orders])
			
			VAR CumulativeOrders =
			    SUMX(
			        FILTER(
			            CategorySummary,
			            [@Orders] >= CurrentOrders
			        ),
			        [@Orders]
			    )
			
			RETURN
			DIVIDE(CumulativeOrders, TotalOrders)
		formatString: 0.00%;-0.00%;0.00%
