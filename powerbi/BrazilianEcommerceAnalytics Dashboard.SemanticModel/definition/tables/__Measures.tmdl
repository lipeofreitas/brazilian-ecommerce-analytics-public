	measure 'KPI | Items in Transit' =
			
			VAR TransitOrders =
			    CALCULATETABLE(
			        VALUES(f_Orders[order_id]),
			        f_Orders[order_status] IN {"shipped", "invoiced"}
			    )
			RETURN
			CALCULATE(
			    COUNTROWS(f_Order_items),
			    TREATAS(TransitOrders, f_Order_items[order_id])
			)
		formatString: #,0
		displayFolder: KPI
