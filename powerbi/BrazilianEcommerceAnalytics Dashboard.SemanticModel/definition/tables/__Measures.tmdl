		displayFolder: Time
		lineageTag: 2d163553-fa52-4ae8-ae44-fc9f88fa12f0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Time | Dynamic Rolling Window Flag' =
			
			VAR MonthsBack =
			    COALESCE([Time | Selected Rolling Months], 12)
			
			VAR EndDateFromSelection =
			    CALCULATE(
			        MAX('Calendar'[full_date]),
			        ALLSELECTED('Calendar')
			    )
			
			VAR EndDateWithData =
			    CALCULATE(
			        MAX(f_Orders[order_approved_ts]),
			        REMOVEFILTERS('Calendar')
			    )
			
			VAR EndDate =
			    MIN(EndDateFromSelection, EndDateWithData)
			
			VAR EndMonth =
			    DATE(YEAR(EndDate), MONTH(EndDate), 1)
			
			VAR StartMonth =
			    EDATE(EndMonth, -MonthsBack + 1)
			
			VAR CurrentMonth =
			    DATE(
			        YEAR(MAX('Calendar'[full_date])),
			        MONTH(MAX('Calendar'[full_date])),
			        1
			    )
			
			RETURN
			IF(
			    CurrentMonth >= StartMonth
			        && CurrentMonth <= EndMonth,
			    1,
			    0
			)
		formatString: 0
		displayFolder: Time
		lineageTag: 641798cd-3302-462b-9547-dd20d43a0b5d

