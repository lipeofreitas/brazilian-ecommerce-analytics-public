	measure 'Time | Dynamic Rolling Order (Approved)' = ```
			
			
			VAR EndDateFromSelection =
			    MAX('Calendar'[YearMonthSort])               
			VAR EndDateWithData =
			    CALCULATE(
			        MAX(f_Orders[order_approved_ts]),
			        REMOVEFILTERS('Calendar')
			    )
			VAR EndDate =
			    MIN(EndDateFromSelection, EndDateWithData)
			VAR MonthsBack =
			    COALESCE([Time | Selected Rolling Months], 12)
			VAR FINAL =
			    CALCULATE(
			        [Other | Orders],
			        DATESINPERIOD('Calendar'[full_date], EndDate, -MonthsBack, MONTH)
			    )
			
			RETURN FINAL
			
			
			```
		formatString: 0
		displayFolder: Time
		lineageTag: 7ff927a1-378a-4b5c-bb7c-0939fcacfa23

	measure 'Time | Dynamic Avg Rolling Revenue (Approved)' = ```
			
			
			// CALCULATE([Finance | Gross Revenue], DATESINPERIOD('Calendar'[full_date], MAX('Calendar'[full_date]), - [Time | Selected Rolling Months], MONTH))
			
