	measure 'Time | Dynamic Rolling Payment Gap % (Approved)' =
			
			
			// VAR EndDateFromSelection =
			//     MAX('Calendar'[YearMonthSort])
			
			// VAR EndDateWithData =
			//     CALCULATE(
			//         MAX(f_Orders[order_approved_ts]),
			//         REMOVEFILTERS('Calendar')
			//     )
			
			// VAR EndDate =
			//     MIN(EndDateFromSelection, EndDateWithData)
			
			// VAR MonthsBack =
			//     COALESCE([Time | Selected Rolling Months], 24)
			
			// VAR RollingPaymentGap =
			//     CALCULATE(
			//         [Finance | Payment Gap],
			//         DATESINPERIOD(
			//             'Calendar'[full_date],
			//             EndDate,
			//             -MonthsBack,
			//             MONTH
			//         )
			//     )
			
			// VAR RollingGrossRevenue =
			//     CALCULATE(
			//         [Finance | Gross Revenue],
			//         DATESINPERIOD(
			//             'Calendar'[full_date],
			//             EndDate,
			//             -MonthsBack,
			//             MONTH
			//         )
			//     )
			
			// RETURN
			//     DIVIDE(RollingPaymentGap, RollingGrossRevenue)
			
			VAR EndDateFromSelection =
			    MAX('Calendar'[full_date])
			
			VAR EndDateWithData =
			    CALCULATE(
			        MAX(f_Orders[order_approved_ts]),
			        REMOVEFILTERS('Calendar')
			    )
			
			VAR EndDate =
			    MIN(EndDateFromSelection, EndDateWithData)
			
			VAR MonthsBack =
			    COALESCE([Time | Selected Rolling Months], 12)
			
			RETURN
			CALCULATE(
			    [Finance | Payment Gap %],
			    DATESINPERIOD(
			        'Calendar'[full_date],
			        EndDate,
			        -MonthsBack,
			        MONTH
			    )
			)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Time
		lineageTag: d8ee1516-93e8-40e2-aa6c-a2d776251f45

