	measure 'Finance | Product Category Cumulative %' =
			
			DIVIDE(
			    [Finance | Product Category Cumulative Revenue],
			    CALCULATE(
			        [Finance | Item Gross Revenue],
			        ALLSELECTED(d_Products[product_category_group])
			    )
			)
		displayFolder: Finance
		lineageTag: 061db7eb-863c-4b2a-89ca-6c24238c5f20

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Finance | Product Category Pareto %' =
			
			VAR TotalRevenue =
			    CALCULATE(
			        [Finance | Item Gross Revenue],
			        ALLSELECTED(d_Products[product_category_group])
			    )
			
			VAR CurrentRevenue =
			    [Finance | Item Gross Revenue]
			
			VAR SummarizedRevenue =
			    SUMMARIZE(
			        ALLSELECTED(d_Products[product_category_group]),
			        d_Products[product_category_group],
			        "Revenue", [Finance | Item Gross Revenue]
			    )
			
			VAR CumulativeRevenue =
			    SUMX(
			        FILTER(
			            SummarizedRevenue,
			            [Revenue] >= CurrentRevenue
			        ),
			        [Revenue]
			    )
			
			RETURN
			DIVIDE(
			    CumulativeRevenue,
			    TotalRevenue
			)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Finance
		lineageTag: 0dfd5c5d-a21b-4660-a612-291c0f56d4a7

	measure 'Finance | Pareto 80% Target' =
			
			0.8
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Finance
		lineageTag: 60d66ef7-fc6d-4d35-bc0e-8e4963df9ae2

	measure 'Other | Pareto Column Color' =
			
			VAR CurrentRevenue =
			    [Finance | Item Gross Revenue]
			
			VAR SummarizedRevenue =
			    ADDCOLUMNS(
			        ALLSELECTED(d_Products[product_category_group]),
			        "@Revenue", [Finance | Item Gross Revenue]
			    )
			
			VAR TotalRevenue =
			    SUMX(
			        SummarizedRevenue,
			        [@Revenue]
			    )
			
			VAR RevenueBeforeCurrent =
			    SUMX(
			        FILTER(
			            SummarizedRevenue,
			            [@Revenue] > CurrentRevenue
			        ),
			        [@Revenue]
			    )
			
			VAR CumulativeBeforeCurrent =
			    DIVIDE(
			        RevenueBeforeCurrent,
			        TotalRevenue
			    )
			
			RETURN
			IF(
			    CumulativeBeforeCurrent < 0.8,
			    "#2ECC71",
			    "#A6A6A6"
			)
		displayFolder: Other
		lineageTag: 3582d250-b770-4711-b8a5-33153ade73aa

