	measure 'Time | Dynamic Rolling Payment Gap Critical Target' =
			
			VAR HasRevenue =
			    NOT ISBLANK([Time | Dynamic Rolling Revenue (Approved)])
			RETURN
			IF(
			    HasRevenue,
